{
  "name": "print-news",
  "version": "1.0.0",
  "description": "Your personal AI-generated morning newspaper — scrapes news, lets AI pick and lay out stories, renders printable A4 broadsheet pages with gpt-image-2",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "issue": "bun run src/index.ts",
    "dry-run": "bun run scripts/dry-run.ts",
    "render-page": "bun run scripts/render-page.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "openai": "^6.45.0",
    "pdf-lib": "^1.17.1",
    "rss-parser": "^3.13.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
