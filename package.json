    "lucide-react": "^1.23.0",
    "next-themes": "^0.4.6",
    "openai": "^6.45.0",
    "pdf-lib": "^1.17.1",
    "playwright-core": "1.60.0",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rss-parser": "^3.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
